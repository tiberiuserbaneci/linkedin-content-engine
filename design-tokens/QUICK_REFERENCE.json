{
  "paletteTl dr": {
    "core": "13 colors total. Material-inspired names. Warm over cool.",
    "neutrals": {
      "Slate": { "dark": "#191919", "medium": "#262625", "light": "#40403E" },
      "Cloud": { "dark": "#666663", "medium": "#91918D", "light": "#BFBFBA" },
      "Ivory": { "dark": "#E5E4DF", "medium": "#F0FDEB", "light": "#FAFAF7" }
    },
    "accents": {
      "BookCloth": "#CC785C",
      "Kraft": "#D4A27F",
      "Manilla": "#EBDBBC"
    },
    "semantic": {
      "Focus": "#2D8AF7",
      "Error": "#EF343B"
    }
  },
  "typographyTlDr": {
    "core": "Anthropic Sans + JetBrains Mono. 4 sizes only. 4 weights only.",
    "sizes": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "18px"
    },
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "styles": {
      "HeadingLarge": "lg + bold",
      "Heading": "md + semibold",
      "HeadingSmall": "sm + semibold",
      "Body": "md + regular",
      "BodyEmphasisized": "md + medium",
      "BodySmall": "sm + regular",
      "Caption": "xs + regular",
      "CaptionEmphasisized": "xs + medium"
    }
  },
  "spacingTlDr": {
    "core": "8px base grid. Multiples of 8 only. Generous, never cramped.",
    "scale": [0, 1, 2, 3, 4, 6, 8, 10, 12, 16, 20, 24, 32, 40, 48, 56, 64],
    "components": {
      "ButtonPadding": "12px vertical/horizontal",
      "InputPadding": "12px vertical/horizontal",
      "CardPadding": "24px",
      "ListGap": "16px",
      "SectionGap": "32-48px"
    }
  },
  "componentRules": {
    "Button": {
      "Primary": {
        "bg": "Focus",
        "text": "White",
        "padding": "12px 16px",
        "radius": "md",
        "hover": "opacity-90"
      },
      "Secondary": {
        "bg": "BookCloth",
        "text": "White",
        "padding": "12px 16px",
        "radius": "md",
        "hover": "opacity-90"
      },
      "Ghost": {
        "bg": "transparent",
        "text": "SlateLight",
        "border": "1px CloudLight",
        "hover": "bg-IvoryMedium"
      },
      "Disabled": {
        "bg": "CloudMedium",
        "text": "CloudLight",
        "opacity": 0.6,
        "cursor": "not-allowed"
      }
    },
    "Card": {
      "Light": {
        "bg": "IvoryLight",
        "border": "1px CloudLight",
        "padding": "24px",
        "radius": "md",
        "shadow": "sm"
      },
      "Dark": {
        "bg": "SlateMedium",
        "border": "1px SlateLight",
        "padding": "24px",
        "radius": "md",
        "shadow": "sm"
      }
    },
    "Input": {
      "default": {
        "bg": "IvoryLight",
        "border": "1px CloudLight",
        "padding": "12px",
        "radius": "md",
        "text": "SlateLight"
      },
      "focus": {
        "ring": "2px Focus",
        "borderColor": "transparent"
      },
      "error": {
        "borderColor": "Error",
        "text": "Error"
      },
      "disabled": {
        "bg": "CloudLight",
        "text": "CloudMedium",
        "opacity": 0.6
      }
    },
    "Chip": {
      "bg": "IvoryMedium",
      "text": "SlateLight",
      "border": "1px CloudLight",
      "padding": "8px 12px",
      "radius": "full",
      "icon": "CloudDark"
    }
  },
  "darkModeTlDr": {
    "core": "Invert Ivory ↔ Slate. Keep accents. Darker shadows.",
    "mapping": {
      "IvoryLight": "SlateDark",
      "IvoryMedium": "SlateMedium",
      "IvoryDark": "IvoryDark (text inverted)",
      "SlateLight": "IvoryDark",
      "SlateMedium": "CloudMedium",
      "SlateDark": "IvoryLight",
      "BookCloth": "BookCloth (no change)",
      "Focus": "Focus (no change)",
      "Error": "Error (no change)"
    }
  },
  "preserve": [
    "Material color names (Slate, Cloud, Book Cloth)",
    "13-color maximum (add = remove)",
    "Warmth priority (terracotta > cool blue)",
    "Minimal typography (4 sizes, 4 weights)",
    "8px grid spacing (multiples only)",
    "Focus blue as THE interactive color",
    "Generous spacing (never cramped)",
    "Accessible contrast (WCAG AA minimum)",
    "Opacity on hover (never color change)",
    "Focus rings on all interactive"
  ],
  "avoid": [
    "Multiple primary colors",
    "Bright/saturated colors",
    "Gradients or color blends",
    "Font mixing",
    "Light weights (< 400)",
    "Typography outside 4-size scale",
    "Odd number spacing (5px, 7px, 11px)",
    "Rounded corners other than md (4px)",
    "Shadows on every element",
    "Missing focus rings",
    "Hover color changes",
    "Semantic color bloat (success, warning, etc)"
  ],
  "applicationChecklist": [
    "Using only Anthropic palette (13 max)",
    "Typography from 4-size scale",
    "Spacing multiples of 8px",
    "Focus elements: Focus blue or BookCloth only",
    "Cards: md border-radius",
    "All interactive: focus rings",
    "Disabled: CloudMedium, opacity 60%",
    "Dark mode: Ivory ↔ Slate inverted",
    "Contrast: WCAG AA minimum (4.5:1)",
    "No gradients, glows, or non-solid fills"
  ],
  "colorUsage": {
    "backgrounds": ["IvoryLight (light)", "SlateDark (dark)"],
    "text": ["SlateLight (light)", "IvoryDark (dark)"],
    "borders": ["CloudLight (light)", "SlateMedium (dark)"],
    "interactive": ["Focus (always)", "BookCloth (secondary only)"],
    "errors": ["Error (always)"],
    "disabled": ["CloudMedium (always)"]
  },
  "typographyUsage": {
    "pageTitle": "LG + Bold",
    "sectionTitle": "MD + Semibold",
    "bodyText": "MD + Regular",
    "secondaryText": "SM + Regular",
    "emphasis": "MD + Medium",
    "labels": "XS + Medium",
    "code": "JetBrains Mono + SM + Regular"
  },
  "focusRing": {
    "width": "2px",
    "color": "Focus (#2D8AF7)",
    "offset": "2px",
    "rule": "Apply to ALL interactive elements"
  },
  "philosophy": "Use a minimal palette of warm, material-inspired colors. Pair with restrained typography and generous spacing. Prioritize accessibility and clarity over decoration. Let the interface become invisible so the content shines."
}
